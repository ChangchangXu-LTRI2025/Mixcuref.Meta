# create a minimal spec (adapt column names as needed)
dat <- data.frame(time = c(1, 2, 3), status = c(1, 0, 1), x = c(0, 1, 1))
spec <- mc_spec(status ~ x, time ~ x, data = dat, time = "time", status = "status", engine = "mixcuref")
fit <- mc_fit(spec)
